{
  "name": "ecom-template",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:client": "turbo run dev --filter=client",
    "dev:admin": "turbo run dev --filter=admin",
    "dev:server": "turbo run dev --filter=server",
    "dev:web": "turbo run dev --filter=client --filter=admin",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "db:generate": "turbo run db:generate",
    "db:migrate": "turbo run db:migrate",
    "db:push": "pnpm --filter @repo/db exec prisma db push",
    "db:seed": "pnpm --filter @repo/db exec tsx src/seed.ts",
    "db:studio": "pnpm --filter @repo/db exec prisma studio"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "@vitest/ui": "^4.0.18",
    "happy-dom": "^20.8.3",
    "prettier": "^3.7.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tsx": "^4.19.0",
    "turbo": "^2.8.15",
    "typescript": "5.9.2",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "nuqs": "^2.8.9",
    "use-debounce": "^10.1.0"
  }
}
