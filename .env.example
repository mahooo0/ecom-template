# PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ecom?schema=public"

# MongoDB
MONGODB_URI="mongodb://root:root@localhost:27017/ecom_orders?authSource=admin"

# Server
PORT=4000
NODE_ENV=development

# Auth (Clerk)
CLERK_SECRET_KEY=sk_test_xxxxx
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxx
CLERK_WEBHOOK_SIGNING_SECRET=whsec_xxxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Payment (Stripe)
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# Client URLs
CLIENT_URL=http://localhost:3002
ADMIN_URL=http://localhost:3003

# Cloudinary
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
